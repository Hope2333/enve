#!/usr/bin/make -f

export DEB_BUILD_MAINT_OPTIONS = hardening=+all

%:
	dh $@

override_dh_auto_configure:
	dh_auto_configure -- \
		-DCMAKE_BUILD_TYPE=Release \
		-DCMAKE_INSTALL_PREFIX=/usr \
		-DENVE_USE_SYSTEM_LIBMYPAINT=ON \
		-DENVE_USE_WEBENGINE=OFF \
		-DENVE_USE_QSCINTILLA=OFF \
		-DENVE_USE_GPERFTOOLS=OFF

override_dh_auto_build:
	dh_auto_build --buildsystem cmake -- -C build

override_dh_auto_install:
	dh_auto_install --buildsystem cmake --destdir=debian/enve

override_dh_strip:
	dh_strip --dbgsym-migration='${package}-dbgsym (<< 0.0.0-1~)'
