# Fix for QuaZip library path in Arch Linux
# This patch adjusts the qmake project to find libquazip in standard Arch locations

--- a/src/core/core.pri
+++ b/src/core/core.pri
@@ -20,6 +20,10 @@ INCLUDEPATH += \
     $$PWD/../../third_party/quazip
 
 LIBS += \
-    -L$$PWD/../../third_party/quazip/quazip -lquazip
+    -L$$PWD/../../third_party/quazip/quazip -lquazip \
+    -L/usr/lib -lquazip-qt5 \
+    -lquazip-qt5
 
+unix {
+    LIBS += -L/usr/lib -lquazip-qt5
+}
