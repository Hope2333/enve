# Maintainer: Your Name <your.email@example.com>
# Contributor: enve Project <https://github.com/MaurycyLiebner/enve>

pkgname=enve
pkgver=2.0.0
pkgrel=1
pkgdesc="A free and open source 2D animation software"
arch=('x86_64')
url="https://maurycyliebner.github.io/enve/"
license=('GPL3')
depends=(
    'qt5-base'
    'qt5-multimedia'
    'qt5-svg'
    'qt5-webengine'
    'qt5-webchannel'
    'qt5-quick3d'
    'ffmpeg'
    'libmypaint'
    'gperftools'
    'hicolor-icon-theme'
)
makedepends=(
    'git'
    'qt5-tools'
    'qt5-webengine'
    'python'
    'curl'
    'patch'
    'make'
    'gcc'
)
optdepends=(
    'librsvg: for SVG support'
    'libwebp: for WebP support'
)
provides=('enve')
conflicts=('enve-git')
backup=()
options=()
source=(
    "${pkgname}-${pkgver}.tar.gz::https://github.com/MaurycyLiebner/enve/archive/refs/tags/${pkgver}.tar.gz"
    'fix-quazip-path.patch'
)
sha256sums=('SKIP'
            'SKIP')

prepare() {
    cd "${srcdir}/${pkgname}-${pkgver}"
    
    # Apply local patches if needed
    if [[ -f "${srcdir}/fix-quazip-path.patch" ]]; then
        patch -Np1 -i "${srcdir}/fix-quazip-path.patch"
    fi
    
    # Initialize submodules
    git submodule update --init --recursive
}

build() {
    cd "${srcdir}/${pkgname}-${pkgver}"
    
    # Build third-party dependencies
    make -C third_party
    
    # Build the application
    cd build/Release
    qmake CONFIG+=release ../../enve.pro
    make -j"$(nproc)"
}

package() {
    cd "${srcdir}/${pkgname}-${pkgver}/build/Release"
    
    # Install main application
    install -Dm755 src/app/enve "${pkgdir}/usr/bin/enve"
    
    # Install shared libraries
    install -Dm755 src/core/libenvecore.so* "${pkgdir}/usr/lib/"
    
    # Install desktop file
    install -Dm644 "${srcdir}/${pkgname}-${pkgver}/org.maurycy.enve.desktop" \
        "${pkgdir}/usr/share/applications/org.maurycy.enve.desktop"
    
    # Install icons (adjust paths as needed)
    install -Dm644 "${srcdir}/${pkgname}-${pkgver}/icons/enve.svg" \
        "${pkgdir}/usr/share/icons/hicolor/scalable/apps/enve.svg"
    
    # Install MIME type
    install -Dm644 "${srcdir}/${pkgname}-${pkgver}/org.maurycy.enve.xml" \
        "${pkgdir}/usr/share/mime/packages/org.maurycy.enve.xml"
}

# vim:set ts=4 sw=4 et:
